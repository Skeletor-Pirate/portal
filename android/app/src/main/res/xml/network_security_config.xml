<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Allow cleartext (HTTP) to local dev server on all possible local addresses -->
    <!-- 10.0.2.2 = Android Emulator's alias for host machine localhost -->
    <!-- 10.0.3.2 = Genymotion emulator alias -->
    <!-- 192.168.x.x / 10.x.x.x = LAN IP of the dev machine -->
    <!-- 187.127.139.208 = Live production server -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">10.0.2.2</domain>
        <domain includeSubdomains="false">10.0.3.2</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="false">187.127.139.208</domain>
    </domain-config>
    <!-- Allow cleartext on the whole 192.168.x.x subnet (physical device on Wi-Fi) -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
